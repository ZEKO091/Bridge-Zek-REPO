{
  "name": "zek-bridge",
  "version": "1.3.0",
  "description": "ZEK BRIDGE - Futuristic AI Terminal Workspace",
  "author": "ZEKO",
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZEKO091/Bridge-Zek-REPO.git"
  },
  "scripts": {
    "dev": "concurrently \"node api/index.js\" \"vite\"",
    "build": "vite build",
    "electron:dev": "concurrently \"node api/index.js\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:release": "npm run build && electron-builder --win --x64 --publish always",
    "electron:build": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "lucide-react": "^0.400.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.zek.bridge",
    "productName": "ZEK BRIDGE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "public/**/*",
      "server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon-256.png",
      "certificateSubjectName": null,
      "certificateSha1": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ZEK BRIDGE"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ZEKO091",
        "repo": "Bridge-Zek-REPO",
        "releaseType": "release"
      }
    ],
    "asar": false
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.2.0"
  }
}



































